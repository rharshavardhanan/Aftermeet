{
  "manifest_version": 3,
  "name": "Aftermeet — Live AI Notes",
  "short_name": "Aftermeet",
  "version": "0.1.0",
  "description": "Capture Zoom & Google Meet calls, transcribe live, and turn them into tasks and minutes.",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Aftermeet",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "http://localhost:4000/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panel.css"],
      "matches": ["https://meet.google.com/*", "https://*.zoom.us/*"]
    }
  ]
}
