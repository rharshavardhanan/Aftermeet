# ──────────────────────────────────────────────────────────────
# Meeting-to-Tasks — environment
# Copy to `.env` and fill in. Never commit `.env`.
# ──────────────────────────────────────────────────────────────

# Database (Supabase Postgres). See supabase/README.md for exact setup.
# Project Settings → Database → Connection string.
#   DATABASE_URL = "Connection pooling" (Transaction, port 6543) + ?pgbouncer=true
#   DIRECT_URL   = "Direct connection"  (Session,   port 5432)  — used by migrations
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# NextAuth
# Generate a secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:4000"

# Google OAuth (console.cloud.google.com → Credentials → OAuth client ID)
# Authorized redirect URI: http://localhost:4000/api/auth/callback/google
# These SAME credentials also power "Export Minutes to Google Docs" (via the
# drive.file scope). No separate key — just enable the Google Drive API in the
# Cloud project and add the .../auth/drive.file scope on the consent screen.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI provider ───────────────────────────────────────────────
# Pick ONE. If GEMINI_API_KEY is set the app uses Gemini; otherwise it falls
# back to OpenAI; with neither, it runs in demo mode (local extractor).

# Groq (FREE — get a key at https://console.groq.com/keys). Preferred for
# speech-to-text (Whisper large-v3) and used as an automatic LLM fallback if
# Gemini's quota fails. Works in regions where Gemini's free tier doesn't.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_STT_MODEL="whisper-large-v3-turbo"

# Gemini (FREE in supported regions — https://aistudio.google.com/apikey).
# Preferred for text processing/extraction. Note: the free tier isn't available
# everywhere; if generateContent returns quota limit: 0, enable billing or rely
# on the Groq fallback above.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# OpenAI (alternative — used for extraction + Whisper transcription). Leave
# blank if you're using Gemini.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-2024-11-20"
OPENAI_TRANSCRIBE_MODEL="whisper-1"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# ── Backend API (Phase 0 split) ─────────────────────────────────
# Base URL of the NestJS backend. Local dev: http://localhost:4001
# Deployed: your Render backend URL, e.g. https://aftermeet-api.onrender.com
NEXT_PUBLIC_API_BASE_URL="http://localhost:4001"
