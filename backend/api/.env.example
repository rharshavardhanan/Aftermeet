# Backend API (NestJS) — copy to .env and fill in.
PORT=4001

# Database (Supabase Postgres) — same values as frontend/web/.env
DATABASE_URL=
DIRECT_URL=

# Comma-separated CORS allow-list (frontend origin + meeting hosts).
# meet.google.com and *.zoom.us are always allowed by pattern in code.
CORS_ORIGINS=http://localhost:4000

# Shared secret for verifying the app JWT minted by the frontend (/api/token).
# MUST be identical to API_JWT_SECRET in frontend/web/.env.
API_JWT_SECRET=

# AI providers (same values as frontend/web/.env)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-2024-11-20
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Public web app URL (Stripe checkout success/cancel redirects)
WEB_APP_URL=http://localhost:4000

# Billing (Stripe). Point the Stripe webhook at <backend>/billing/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# Google OAuth (for Docs export token refresh — same values as frontend/web/.env)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
